# Recraft API key — used by the recraft MCP server (.mcp.json) for the
# graphic-novel / illustrated style. Get one at https://www.recraft.ai/.
RECRAFT_API_KEY=

# OpenRouter API key — used by scripts/openrouter-image.mjs for the
# realistic-faceless / photographic style. Get one at https://openrouter.ai/.
OPENROUTER_API_KEY=

# Default image-output model slug for scripts/openrouter-image.mjs.
# Used when --model is not passed on the CLI. Pick any image-output-capable
# model from the OpenRouter catalog — choice is intentionally left to the user.
OPENROUTER_IMAGE_MODEL=

# OpenRouter model used for decorative PNG assets (stars, arrows, badges) —
# small icons with transparent background, rendered via
# scripts/openrouter-image.mjs and (optionally) cleaned up via Recraft
# remove_background. Kept separate from OPENROUTER_IMAGE_MODEL because
# decor generally needs a different model (sticker-friendly).
OPENROUTER_DECOR_MODEL=
